---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// 取出所有文章，按发布时间倒序，首页展示最新 6 篇
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

// 书架：你读过/推荐的书。以后想加书，往这个数组里加一行即可。
const books = [
	{ title: '思考，快与慢', author: 'Kahneman' },
	{ title: '我们如何学习', author: 'Dehaene' },
	{ title: '心流', author: 'Csikszentmihalyi' },
	{ title: '行为', author: 'Sapolsky' },
	{ title: '原子习惯', author: 'Clear' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ===== Hero 大标题区 ===== -->
			<section class="hero">
				<h1>GoodEvelyn</h1>
				<p class="subtitle">神经科学 · 心理学 · 个人成长</p>
				<p class="intro">
					把复杂的脑科学讲清楚，写给好奇的你。每周更新。
				</p>
			</section>

			<!-- ===== 最新文章卡片网格 ===== -->
			<section class="section">
				<div class="section-head">
					<h2>最新文章</h2>
					<a href="/blog">查看全部 →</a>
				</div>
				<ul class="card-grid">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											class="card-img"
											width={600}
											height={340}
											src={post.data.heroImage}
											alt=""
										/>
									)}
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<!-- ===== 书架 ===== -->
			<section class="section">
				<div class="section-head">
					<h2>书架</h2>
				</div>
				<div class="shelf">
					{
						books.map((book) => (
							<div class="book">
								<span class="book-title">{book.title}</span>
								<span class="book-author">{book.author}</span>
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />

		<style>
			main {
				width: 960px;
			}

			/* Hero */
			.hero {
				padding: 3rem 0 2rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 4rem;
				letter-spacing: -0.02em;
				margin: 0;
			}
			.hero .subtitle {
				font-size: 1.3rem;
				color: rgb(var(--gray));
				margin: 0.5rem 0 0;
			}
			.hero .intro {
				font-size: 1.1rem;
				color: rgb(var(--gray-dark));
				max-width: 36rem;
				margin-top: 1rem;
			}

			/* 区块标题行 */
			.section {
				margin-bottom: 3.5rem;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1.5rem;
			}
			.section-head h2 {
				font-size: 1.6rem;
				margin: 0;
			}
			.section-head a {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.95rem;
			}
			.section-head a:hover {
				color: rgb(var(--black));
			}

			/* 文章卡片网格 */
			.card-grid {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			.card-grid a {
				display: block;
				text-decoration: none;
			}
			.card-img {
				width: 100%;
				height: auto;
				border-radius: 10px;
				margin-bottom: 0.75rem;
				filter: grayscale(100%);
				transition: filter 0.3s ease;
			}
			.card-grid a:hover .card-img {
				filter: grayscale(0%);
			}
			.card-title {
				font-size: 1.1rem;
				color: rgb(var(--black));
				margin: 0 0 0.25rem;
				line-height: 1.3;
			}
			.card-date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
			}

			/* 书架 */
			.shelf {
				display: flex;
				gap: 1rem;
				overflow-x: auto;
				padding-bottom: 0.5rem;
			}
			.book {
				flex: 0 0 auto;
				width: 110px;
				height: 160px;
				border: 1px solid rgb(var(--black));
				border-radius: 4px;
				padding: 0.75rem;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				background: #fff;
				transition: transform 0.2s ease;
			}
			.book:hover {
				transform: translateY(-4px);
			}
			.book-title {
				font-size: 0.95rem;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.book-author {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}

			/* 移动端自适应 */
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.6rem;
				}
				.card-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
